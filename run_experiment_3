#!/usr/bin/env bash
set -euo pipefail

# MARL experiment batch 3: VDN double Q on heterogeneous plants.
# Single-stage training with config-defined reward, reward normalization off.

PROJECT_ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
cd "${PROJECT_ROOT}"

SEED="${SEED:-0}"
OUTPUT_ROOT="${OUTPUT_ROOT:-outputs}"

TOTAL_TIMESTEPS="${TOTAL_TIMESTEPS:-15000000}"
EPS_DECAY_STEPS="${EPS_DECAY_STEPS:-$((TOTAL_TIMESTEPS * 60 / 100))}"
HANDCRAFTED_COMM_BITS="${HANDCRAFTED_COMM_BITS:-4}"
AGE_COMM="${AGE_COMM:-0}"
AGE_COMM_BITS="${AGE_COMM_BITS:-4}"
STATE_COMM="${STATE_COMM:-0}"
BROADCAST_PENALTY_ALPHA="${BROADCAST_PENALTY_ALPHA:-0.0}"
# Set VOU_QUANTILE_EDGES=1 to auto-search the threshold and compute
# equal-probability quantile bin edges instead of geometric bins.
VOU_QUANTILE_EDGES="${VOU_QUANTILE_EDGES:-0}"
VOU_SEARCH_ITERS="${VOU_SEARCH_ITERS:-12}"
VOU_SEARCH_SAMPLES="${VOU_SEARCH_SAMPLES:-8}"
VOU_SEARCH_EVAL_SEEDS="${VOU_SEARCH_EVAL_SEEDS:-32}"
VOU_THRESHOLD_MIN="${VOU_THRESHOLD_MIN:-0.01}"
VOU_THRESHOLD_MAX="${VOU_THRESHOLD_MAX:-10}"

timestamp="$(date -u +%Y%m%dT%H%M%SZ)"
run_root="${OUTPUT_ROOT}/exp_3_vdn_doubleq_${timestamp}_seed${SEED}"

mkdir -p "${run_root}/logs"

PYTHON_BIN=""
if [[ -f "${HOME}/.venv/bin/activate" ]]; then
  # shellcheck disable=SC1090
  source "${HOME}/.venv/bin/activate"
  PYTHON_BIN="python"
elif command -v python >/dev/null 2>&1; then
  PYTHON_BIN="python"
elif command -v python3 >/dev/null 2>&1; then
  PYTHON_BIN="python3"
else
  echo "Could not find python or python3 (and ~/.venv not found)." >&2
  exit 1
fi

if [[ -n "${CONFIG_PATH:-}" ]]; then
  config_path="${CONFIG_PATH}"
elif [[ "${CONFIG:-hetero}" == "homo" ]]; then
  config_path="configs/marl_absolute_plants.json"
else
  config_path="configs/marl_absolute_plants_hetero.json"
fi
if [[ ! -f "${config_path}" ]]; then
  echo "Config not found: ${config_path}" >&2
  exit 1
fi
echo "Using config: ${config_path}"

next_run_dir() {
  local algo="$1"
  local idx=0
  local candidate
  while :; do
    candidate="${run_root}/${algo}_${idx}"
    if [[ ! -d "${candidate}" ]]; then
      echo "${candidate}"
      return 0
    fi
    idx=$((idx + 1))
  done
}

run_one() {
  local algo_module="$1"
  local algo_label="$2"
  local run_label="$3"
  shift 3

  local common_args=(
    --config "${config_path}"
    --output-root "${run_root}"
    --seed "${SEED}"
    --total-timesteps "${TOTAL_TIMESTEPS}"
    --n-envs 8
    --n-eval-envs 8
    --n-eval-episodes 80
    --episode-length 250
  )

  local log_path="${run_root}/logs/${run_label}.log"
  local expected_dir
  expected_dir="$(next_run_dir "${algo_label}")"

  echo "=== ${run_label} ==="
  echo "Logging to: ${log_path}"
  echo "Expected run dir: ${expected_dir}"

  PYTHONUNBUFFERED=1 "${PYTHON_BIN}" -m "${algo_module}" "${common_args[@]}" "$@" 2>&1 | tee "${log_path}"

  local final_dir="${run_root}/${run_label}"
  if [[ ! -d "${expected_dir}" ]]; then
    echo "Expected run dir missing: ${expected_dir}" >&2
    exit 1
  fi
  if [[ -e "${final_dir}" ]]; then
    echo "Target run dir already exists: ${final_dir}" >&2
    exit 1
  fi
  mv "${expected_dir}" "${final_dir}"
}

# ------------------------------------------------------------------
# VoU threshold search + quantile edge computation (opt-in)
# ------------------------------------------------------------------
hcomm_args=()
if [[ "${VOU_QUANTILE_EDGES}" == "1" ]]; then
  echo "=== VoU threshold search ==="
  vou_output_dir="${run_root}/vou_search"

  PYTHONUNBUFFERED=1 "${PYTHON_BIN}" -m tools.search_vou_threshold \
    --config "${config_path}" \
    --threshold-min "${VOU_THRESHOLD_MIN}" \
    --threshold-max "${VOU_THRESHOLD_MAX}" \
    --iters "${VOU_SEARCH_ITERS}" \
    --samples-per-iter "${VOU_SEARCH_SAMPLES}" \
    --eval-num-seeds "${VOU_SEARCH_EVAL_SEEDS}" \
    --collect-bits "${HANDCRAFTED_COMM_BITS}" \
    --output-dir "${vou_output_dir}" \
    2>&1 | tee "${run_root}/logs/vou_search.log"

  HANDCRAFTED_COMM_THRESHOLD="$("${PYTHON_BIN}" -c "
import json, sys
with open('${vou_output_dir}/search_summary.json') as f:
    s = json.load(f)
br = s.get('best_result')
if br is None:
    print('ERROR: no best_result in search summary', file=sys.stderr); sys.exit(1)
print(br['theta'])
")"
  HANDCRAFTED_COMM_EDGES="$("${PYTHON_BIN}" -c "
import json
with open('${vou_output_dir}/quantile_edges.json') as f:
    d = json.load(f)
print(json.dumps(d['edges']['bits_${HANDCRAFTED_COMM_BITS}']['edges']))
")"
  echo "VoU threshold: ${HANDCRAFTED_COMM_THRESHOLD}"
  echo "Quantile edges (${HANDCRAFTED_COMM_BITS} bits): ${HANDCRAFTED_COMM_EDGES}"

  hcomm_args=(
    --error_comm
    --set "observation.error_comm_bits=${HANDCRAFTED_COMM_BITS}"
    --set "observation.error_comm_edges=${HANDCRAFTED_COMM_EDGES}"
  )
fi

# ------------------------------------------------------------------
# Age-based communication (opt-in)
# ------------------------------------------------------------------
age_comm_args=()
if [[ "${AGE_COMM}" == "1" ]]; then
  age_comm_args=(
    --age_comm
    --set "observation.age_comm_bits=${AGE_COMM_BITS}"
  )
fi

# ------------------------------------------------------------------
# State broadcast communication (opt-in)
# ------------------------------------------------------------------
state_comm_args=()
if [[ "${STATE_COMM}" == "1" ]]; then
  state_comm_args=(
    --state_comm
    --set "reward.broadcast_penalty_alpha=${BROADCAST_PENALTY_ALPHA}"
  )
fi

run_one "algorithms.marl_vdn" "vdn" "vdn_doubleq" \
  --double-q --batch-size 512 --learning-rate 2.5e-5 \
  --epsilon-decay-steps "${EPS_DECAY_STEPS}" \
  --eval-freq 40000 \
  --no-normalize-obs \
  --feature-norm \
  --layer-norm \
  "${hcomm_args[@]+${hcomm_args[@]}}" \
  "${age_comm_args[@]+${age_comm_args[@]}}" \
  "${state_comm_args[@]+${state_comm_args[@]}}"

zip_path="${run_root}.zip"
if command -v zip >/dev/null 2>&1; then
  (cd "${OUTPUT_ROOT}" && zip -qr "$(basename "${zip_path}")" "$(basename "${run_root}")")
else
  "${PYTHON_BIN}" - <<PY
import zipfile
from pathlib import Path

src = Path("${run_root}")
dst = Path("${zip_path}")
with zipfile.ZipFile(dst, "w", compression=zipfile.ZIP_DEFLATED) as zf:
    for p in src.rglob("*"):
        zf.write(p, p.relative_to(src.parent))
print(f"Wrote zip: {dst}")
PY
fi

echo "Done."
echo "Run root: ${run_root}"
echo "Zipped to: ${zip_path}"
